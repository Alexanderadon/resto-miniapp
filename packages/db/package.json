{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./seed-data": "./src/seed-data.json"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate:sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script",
    "seed": "node --experimental-strip-types src/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "prisma": "7.8.0",
    "typescript": "5.9.3"
  }
}
