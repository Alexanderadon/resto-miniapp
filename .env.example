# ── База данных (Postgres / Supabase) ────────────────────────────────
# Пул соединений (pgbouncer) для serverless-рантайма
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# ── Telegram ─────────────────────────────────────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=""
# Секрет, который Telegram шлёт в X-Telegram-Bot-Api-Secret-Token (придумайте свой)
TELEGRAM_WEBHOOK_SECRET=""
# Telegram ID администраторов через запятую (доступ к /admin)
ADMIN_TG_IDS=""

# ── Сессии ───────────────────────────────────────────────────────────
# Секрет подписи JWT-сессии (openssl rand -hex 32). НЕ равен BOT_TOKEN.
SESSION_SECRET=""

# ── iiko-адаптер ─────────────────────────────────────────────────────
# 'mock' — единственный рабочий провайдер (см. packages/iiko-adapter/README)
IIKO_PROVIDER="mock"
IIKO_MOCK_FAILURE_RATE="0"

# ── Stripe (test mode, фаза v1) ──────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Приложение ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
